# EditorConfig — AiAgent-Java
# https://editorconfig.org

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Java source files
[*.java]
max_line_length = 120

# XML files (Maven POM, MyBatis mappers)
[*.xml]
indent_size = 4

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# SQL files
[*.sql]
indent_size = 4

# Properties files
[*.properties]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
